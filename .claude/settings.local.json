{
  "permissions": {
    "allow": [
      "Bash(rtk find *)",
      "Bash(rtk ls *)",
      "Bash(open *)",
      "Bash(node *)",
      "Bash(rtk read *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks":[{ 
          "type": "command", "command": "_node --test_","statusMessage": "Running tests ..."
        }]
      }
    ]
  }
}
